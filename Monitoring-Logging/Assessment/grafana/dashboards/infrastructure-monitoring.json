{
  "uid": "infra-monitoring-v1",
  "title": "Dashboard 1: Infrastructure Monitoring",
  "description": "System-level metrics from Node Exporter — CPU, Memory, Disk",
  "tags": ["infrastructure", "node-exporter", "system"],
  "timezone": "browser",
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "schemaVersion": 39,
  "version": 1,
  "panels": [
    {
      "id": 1,
      "title": "CPU Usage (%)",
      "description": "Percentage of CPU time spent in non-idle states across all cores",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "red", "value": 85 }
            ]
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "opacity",
            "showPoints": "never",
            "spanNulls": true
          },
          "color": { "mode": "thresholds" }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "expr": "100 - (avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[2m])) * 100)",
          "legendFormat": "CPU Usage - {{instance}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "CPU Usage — Current",
      "description": "Current CPU utilisation as a gauge",
      "type": "gauge",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "red", "value": 85 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "showThresholdLabels": false, "showThresholdMarkers": true },
      "targets": [
        {
          "expr": "100 - (avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[2m])) * 100)",
          "legendFormat": "CPU %",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "CPU Mode Breakdown",
      "description": "Time distribution across CPU modes (user, system, iowait, etc.)",
      "type": "timeseries",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": { "lineWidth": 1, "fillOpacity": 20, "stacking": { "mode": "normal" }, "showPoints": "never" }
        }
      },
      "targets": [
        {
          "expr": "avg by (mode) (rate(node_cpu_seconds_total{mode!=\"idle\"}[2m])) * 100",
          "legendFormat": "{{mode}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Memory Usage (%)",
      "description": "Percentage of physical RAM currently in use",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20,
            "gradientMode": "opacity",
            "showPoints": "never"
          },
          "color": { "mode": "thresholds" }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "expr": "((node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes) / node_memory_MemTotal_bytes) * 100",
          "legendFormat": "Memory Used %",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Memory — Current",
      "description": "Current RAM utilisation gauge",
      "type": "gauge",
      "gridPos": { "x": 12, "y": 8, "w": 6, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdMarkers": true },
      "targets": [
        {
          "expr": "((node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes) / node_memory_MemTotal_bytes) * 100",
          "legendFormat": "Memory %",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "Memory Breakdown (GB)",
      "description": "Total vs Used vs Available memory in gigabytes",
      "type": "bargauge",
      "gridPos": { "x": 18, "y": 8, "w": 6, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        }
      },
      "options": { "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"] }, "displayMode": "gradient" },
      "targets": [
        { "expr": "node_memory_MemTotal_bytes", "legendFormat": "Total RAM", "refId": "A" },
        { "expr": "node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes", "legendFormat": "Used RAM", "refId": "B" },
        { "expr": "node_memory_MemAvailable_bytes", "legendFormat": "Available RAM", "refId": "C" }
      ]
    },
    {
      "id": 7,
      "title": "Disk Usage (%)",
      "description": "Percentage of disk space used on the root filesystem",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          },
          "custom": { "lineWidth": 2, "fillOpacity": 25, "showPoints": "never" },
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [
        {
          "expr": "100 - ((node_filesystem_avail_bytes{mountpoint=\"/\",fstype!=\"tmpfs\"} / node_filesystem_size_bytes{mountpoint=\"/\",fstype!=\"tmpfs\"}) * 100)",
          "legendFormat": "Disk Used % ({{mountpoint}})",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "title": "Disk — Current",
      "description": "Current disk usage gauge for root filesystem",
      "type": "gauge",
      "gridPos": { "x": 12, "y": 16, "w": 6, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdMarkers": true },
      "targets": [
        {
          "expr": "100 - ((node_filesystem_avail_bytes{mountpoint=\"/\",fstype!=\"tmpfs\"} / node_filesystem_size_bytes{mountpoint=\"/\",fstype!=\"tmpfs\"}) * 100)",
          "legendFormat": "Disk %",
          "refId": "A"
        }
      ]
    },
    {
      "id": 9,
      "title": "Disk I/O (bytes/sec)",
      "description": "Read and write throughput on all block devices",
      "type": "timeseries",
      "gridPos": { "x": 18, "y": 16, "w": 6, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": { "lineWidth": 1, "fillOpacity": 10, "showPoints": "never" }
        }
      },
      "targets": [
        { "expr": "rate(node_disk_read_bytes_total[2m])", "legendFormat": "Read - {{device}}", "refId": "A" },
        { "expr": "rate(node_disk_written_bytes_total[2m])", "legendFormat": "Write - {{device}}", "refId": "B" }
      ]
    },
    {
      "id": 10,
      "title": "Network Traffic (bytes/sec)",
      "description": "Inbound and outbound network throughput per interface",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 24, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": { "lineWidth": 2, "fillOpacity": 10, "showPoints": "never" }
        }
      },
      "targets": [
        { "expr": "rate(node_network_receive_bytes_total{device!~\"lo|veth.*\"}[2m])", "legendFormat": "RX - {{device}}", "refId": "A" },
        { "expr": "rate(node_network_transmit_bytes_total{device!~\"lo|veth.*\"}[2m])", "legendFormat": "TX - {{device}}", "refId": "B" }
      ]
    },
    {
      "id": 11,
      "title": "System Load Average",
      "description": "1m / 5m / 15m load averages",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 24, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 10, "showPoints": "never" }
        }
      },
      "targets": [
        { "expr": "node_load1", "legendFormat": "Load 1m", "refId": "A" },
        { "expr": "node_load5", "legendFormat": "Load 5m", "refId": "B" },
        { "expr": "node_load15", "legendFormat": "Load 15m", "refId": "C" }
      ]
    }
  ],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "label": "Datasource",
        "hide": 0
      }
    ]
  }
}
